# --- Meta Ads (Facebook Marketing API) ---
# System User long-lived token from Business Manager
META_ACCESS_TOKEN=
# Ad account ID without "act_" prefix
META_AD_ACCOUNT_ID=
META_API_VERSION=v22.0

# --- Calendly ---
# Personal Access Token from Calendly → Integrations → API & Webhooks.
# The PAT must belong to a user with **owner or admin** role on the organization,
# otherwise org-scoped /scheduled_events and /event_types calls return 403.
CALENDLY_API_TOKEN=
# Organization URI (https://api.calendly.com/organizations/<uuid>) — get via:
#   curl -H "Authorization: Bearer $CALENDLY_API_TOKEN" https://api.calendly.com/users/me
# and copy `resource.current_organization`. Counts events booked by ANY user
# in the org (not just the token holder).
CALENDLY_ORGANIZATION_URI=

# --- Airtable ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appuQ0UBJRXSTztOH
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_LEADS_TABLE=Leads

# --- Dashboard tuning ---
# Reference Customer Acquisition Cost shown beside the actual CAC. Optional.
TARGET_CAC=

# --- Frontend login (optional) ---
# When set, all routes (except /login) require the user to log in with this
# password via the /login form. Cookie session lasts 30 days.
# Leave empty to disable the gate (e.g. on localhost).
DASHBOARD_PASSWORD=

# --- Feedback webhook ---
# n8n webhook URL that receives submissions from the floating Feedback button.
# Multipart payload: `text` (string) + optional `image` (file). Leave empty to
# disable: the API route then returns 503 and the dialog shows a config error.
N8N_FEEDBACK_WEBHOOK_URL=

# --- Optional ---
# LOG_LEVEL=debug
# SKIP_ENV_VALIDATION=true
