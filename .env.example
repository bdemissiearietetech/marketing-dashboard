# --- Database (docker-compose.yml) ---
DATABASE_URL=postgresql://marketing:marketing@localhost:5432/marketing_dashboard

# --- Meta Ads (Facebook Marketing API) ---
# System User long-lived token from Business Manager
META_ACCESS_TOKEN=
# Ad account ID without "act_" prefix
META_AD_ACCOUNT_ID=
META_API_VERSION=v22.0

# --- Calendly ---
# Personal Access Token from Calendly → Integrations → API & Webhooks
CALENDLY_API_TOKEN=
# User URI (https://api.calendly.com/users/<uuid>) — get via:
#   curl -H "Authorization: Bearer $CALENDLY_API_TOKEN" https://api.calendly.com/users/me
CALENDLY_USER_URI=

# --- Airtable ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appuQ0UBJRXSTztOH
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_LEADS_TABLE=Leads

# --- Basic Auth (optional) ---
# When both set, all non-asset routes require HTTP Basic Auth.
# Leave empty to disable (e.g. on localhost).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Optional ---
# LOG_LEVEL=debug
# SKIP_ENV_VALIDATION=true
