generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CacheEntry {
  key       String   @id
  payload   Json
  fetchedAt DateTime @default(now())
  ttlSec    Int

  @@index([fetchedAt])
}

model Settings {
  id        String   @id @default("default")
  targetCac Float?
  updatedAt DateTime @updatedAt
}
